{
  "name": "confluence-md-sync",
  "version": "0.2.0",
  "description": "Publish Markdown to Confluence (Data Center & Cloud): idempotent page sync, attachment dedup, tables and a pluggable macro system",
  "keywords": [
    "confluence",
    "markdown",
    "sync",
    "publish",
    "atlassian",
    "docs-as-code",
    "storage-format",
    "macros"
  ],
  "license": "MIT",
  "author": "hexstyle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexstyle/confluence-md-sync.git"
  },
  "bugs": {
    "url": "https://github.com/hexstyle/confluence-md-sync/issues"
  },
  "homepage": "https://github.com/hexstyle/confluence-md-sync#readme",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./csv": {
      "types": "./dist/csv.d.ts",
      "import": "./dist/csv.js"
    },
    "./macros": {
      "types": "./dist/macros/index.d.ts",
      "import": "./dist/macros/index.js"
    }
  },
  "bin": {
    "confluence-md-sync": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.0",
    "bpmn-to-image": "^0.7.0",
    "puppeteer": "^24.43.1",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "bpmn-to-image": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "bpmn-to-image": {
      "optional": true
    }
  },
  "overrides": {
    "puppeteer": "$puppeteer"
  }
}
